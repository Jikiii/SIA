-- =====================================================
-- DROP DATABASE IF EXISTS AND CREATE NEW
-- =====================================================
DROP DATABASE IF EXISTS dreamhome_pit;
CREATE DATABASE dreamhome_pit;
USE dreamhome_pit;

-- =====================================================
-- 1. BRANCH table
-- =====================================================
CREATE TABLE Branch (
    BranchID INT AUTO_INCREMENT PRIMARY KEY,
    BranchName VARCHAR(100) NOT NULL,
    Street VARCHAR(100),
    Area VARCHAR(100),
    City VARCHAR(100) NOT NULL,
    PostCode VARCHAR(20),
    ContactNo VARCHAR(20),
    Email VARCHAR(100)
);

-- =====================================================
-- 2. STAFF table
-- =====================================================
CREATE TABLE Staff (
    StaffID INT AUTO_INCREMENT PRIMARY KEY,
    BranchID INT NOT NULL,
    FirstName VARCHAR(50) NOT NULL,
    LastName VARCHAR(50) NOT NULL,
    Address VARCHAR(200),
    Phone VARCHAR(20),
    Email VARCHAR(100),
    Gender CHAR(1),
    BirthDate DATE,
    Position VARCHAR(50) NOT NULL,
    Salary DECIMAL(10,2) NOT NULL,
    HireDate DATE NOT NULL,
    TypingSpeed INT,
    FOREIGN KEY (BranchID) REFERENCES Branch(BranchID)
        ON UPDATE CASCADE ON DELETE RESTRICT
);

-- =====================================================
-- 3. SUPERVISOR table
-- =====================================================
CREATE TABLE Supervisor (
    SupervisorID INT AUTO_INCREMENT PRIMARY KEY,
    StaffID INT NOT NULL UNIQUE,
    CarAllowance DECIMAL(10,2),
    BonusPayment DECIMAL(10,2),
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE CASCADE
);

-- =====================================================
-- 4. NEXT OF KIN table
-- =====================================================
CREATE TABLE NextOfKin (
    KinID INT AUTO_INCREMENT PRIMARY KEY,
    StaffID INT NOT NULL,
    FullName VARCHAR(100) NOT NULL,
    Relationship VARCHAR(50),
    Address VARCHAR(200),
    Phone VARCHAR(20),
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE CASCADE
);

-- =====================================================
-- 5. PROPERTY TYPE table
-- =====================================================
CREATE TABLE PropertyType (
    PropertyTypeID INT AUTO_INCREMENT PRIMARY KEY,
    TypeName VARCHAR(50) NOT NULL UNIQUE
);

-- =====================================================
-- 6. OWNER table
-- =====================================================
CREATE TABLE Owner (
    OwnerID INT AUTO_INCREMENT PRIMARY KEY,
    FullName VARCHAR(100) NOT NULL,
    Address VARCHAR(200),
    Phone VARCHAR(20)
);

-- =====================================================
-- 7. PROPERTY table
-- =====================================================
CREATE TABLE Property (
    PropertyID INT AUTO_INCREMENT PRIMARY KEY,
    StaffID INT,
    OwnerID INT,
    PropertyTypeID INT,
    StreetName VARCHAR(100),
    District VARCHAR(100),
    City VARCHAR(50),
    PostalCode VARCHAR(20),
    Rooms INT,
    RentAmount DECIMAL(10,2),
    Status ENUM('Available', 'Rented', 'Withdrawn') DEFAULT 'Available',
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (OwnerID) REFERENCES Owner(OwnerID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (PropertyTypeID) REFERENCES PropertyType(PropertyTypeID)
        ON UPDATE CASCADE ON DELETE SET NULL
);

-- =====================================================
-- 8. RENTER table
-- =====================================================
CREATE TABLE Renter (
    RenterID INT AUTO_INCREMENT PRIMARY KEY,
    BranchID INT,
    StaffID INT,
    FirstName VARCHAR(50),
    LastName VARCHAR(50),
    Address VARCHAR(200),
    Phone VARCHAR(20),
    DateApproved DATE,
    FOREIGN KEY (BranchID) REFERENCES Branch(BranchID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE SET NULL
);

-- =====================================================
-- 9. PROSPECTIVE RENTER table
-- =====================================================
CREATE TABLE ProspectiveRenter (
    ProspectiveRenterID INT AUTO_INCREMENT PRIMARY KEY,
    BranchID INT,
    PropertyTypeID INT,
    FirstName VARCHAR(50),
    LastName VARCHAR(50),
    Address VARCHAR(200),
    MaxRent DECIMAL(10,2),
    Comment TEXT,
    FOREIGN KEY (BranchID) REFERENCES Branch(BranchID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (PropertyTypeID) REFERENCES PropertyType(PropertyTypeID)
        ON UPDATE CASCADE ON DELETE SET NULL
);

-- =====================================================
-- 10. PAYMENT METHOD table
-- =====================================================
CREATE TABLE PaymentMethod (
    PaymentMethodID INT AUTO_INCREMENT PRIMARY KEY,
    MethodType VARCHAR(50) NOT NULL UNIQUE
);

-- =====================================================
-- 11. LEASE table
-- =====================================================
CREATE TABLE Lease (
    LeaseID INT AUTO_INCREMENT PRIMARY KEY,
    PropertyID INT,
    RenterID INT,
    StaffID INT,
    PaymentMethodID INT,
    Rent DECIMAL(10,2),
    DepositAmount DECIMAL(10,2),
    IsDepositPaid BOOLEAN DEFAULT FALSE,
    StartDate DATE NOT NULL,
    EndDate DATE NOT NULL,
    LeaseDuration INT,
    Status ENUM('Active', 'Expired', 'Terminated') DEFAULT 'Active',
    FOREIGN KEY (PropertyID) REFERENCES Property(PropertyID)
        ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (RenterID) REFERENCES Renter(RenterID)
        ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (PaymentMethodID) REFERENCES PaymentMethod(PaymentMethodID)
        ON UPDATE CASCADE ON DELETE SET NULL,
    CONSTRAINT chk_lease_duration CHECK (LeaseDuration BETWEEN 3 AND 12),
    CONSTRAINT chk_lease_dates CHECK (EndDate > StartDate)
);

-- =====================================================
-- 12. INSPECTION table
-- =====================================================
CREATE TABLE Inspection (
    InspectionID INT AUTO_INCREMENT PRIMARY KEY,
    PropertyID INT,
    StaffID INT,
    InspectDate DATE NOT NULL,
    Notes TEXT,
    FOREIGN KEY (PropertyID) REFERENCES Property(PropertyID)
        ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (StaffID) REFERENCES Staff(StaffID)
        ON UPDATE CASCADE ON DELETE RESTRICT
);

